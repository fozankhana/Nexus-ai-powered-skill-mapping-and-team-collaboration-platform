diff --git a/src/__tests__/api/ai/gap-analysis.test.ts b/src/__tests__/api/ai/gap-analysis.test.ts
new file mode 100644
index 0000000..e1e9476
--- /dev/null
+++ b/src/__tests__/api/ai/gap-analysis.test.ts
@@ -0,0 +1,143 @@
+import { describe, it, expect, vi, beforeEach } from "vitest";
+import { NextRequest } from "next/server";
+
+vi.mock("@/lib/prisma", () => ({
+  prisma: {
+    skillGapAnalysis: {
+      findFirst: vi.fn(),
+      create: vi.fn(),
+    },
+  },
+}));
+
+vi.mock("next-auth", () => ({
+  getServerSession: vi.fn(),
+}));
+
+vi.mock("@/lib/auth", () => ({ authOptions: {} }));
+
+vi.mock("@/lib/skill-gap", () => ({
+  runGapAnalysis: vi.fn().mockResolvedValue(undefined),
+}));
+
+import { prisma } from "@/lib/prisma";
+import { getServerSession } from "next-auth";
+import { GET, POST } from "@/app/api/ai/gap-analysis/route";
+
+const mockSession = { user: { id: "user-1", email: "test@example.com" } };
+
+function makeGetRequest(projectId?: string) {
+  const url = projectId
+    ? `http://localhost/api/ai/gap-analysis?projectId=${projectId}`
+    : "http://localhost/api/ai/gap-analysis";
+  return new NextRequest(url, { method: "GET" });
+}
+
+function makePostRequest(body: unknown) {
+  return new NextRequest("http://localhost/api/ai/gap-analysis", {
+    method: "POST",
+    headers: { "Content-Type": "application/json" },
+    body: JSON.stringify(body),
+  });
+}
+
+describe("GET /api/ai/gap-analysis", () => {
+  beforeEach(() => vi.clearAllMocks());
+
+  it("returns 401 when unauthenticated", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(null);
+    const res = await GET(makeGetRequest("project-1"));
+    expect(res.status).toBe(401);
+  });
+
+  it("returns null when no projectId provided", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    const res = await GET(makeGetRequest());
+    expect(res.status).toBe(200);
+    const body = await res.json();
+    expect(body).toBeNull();
+  });
+
+  it("returns the latest analysis for a project", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    const mockAnalysis = {
+      id: "analysis-1",
+      projectId: "project-1",
+      status: "COMPLETED",
+      gapScore: 45,
+    };
+    vi.mocked(prisma.skillGapAnalysis.findFirst).mockResolvedValue(
+      mockAnalysis as never
+    );
+
+    const res = await GET(makeGetRequest("project-1"));
+    expect(res.status).toBe(200);
+    const body = await res.json();
+    expect(body.id).toBe("analysis-1");
+    expect(body.gapScore).toBe(45);
+  });
+});
+
+describe("POST /api/ai/gap-analysis", () => {
+  beforeEach(() => vi.clearAllMocks());
+
+  it("returns 401 when unauthenticated", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(null);
+    const res = await POST(makePostRequest({ projectId: "project-1" }));
+    expect(res.status).toBe(401);
+  });
+
+  it("returns 400 when projectId is missing", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    const res = await POST(makePostRequest({}));
+    expect(res.status).toBe(400);
+  });
+
+  it("returns 400 when projectId is empty string", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    const res = await POST(makePostRequest({ projectId: "" }));
+    expect(res.status).toBe(400);
+  });
+
+  it("returns 202 and triggers analysis on valid request", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    vi.mocked(prisma.skillGapAnalysis.create).mockResolvedValue({
+      id: "analysis-123",
+      status: "PROCESSING",
+    } as never);
+
+    const res = await POST(makePostRequest({ projectId: "project-1" }));
+    expect(res.status).toBe(202);
+    const body = await res.json();
+    expect(body.id).toBe("analysis-123");
+    expect(body.status).toBe("PROCESSING");
+  });
+
+  it("creates analysis record with PROCESSING status", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    vi.mocked(prisma.skillGapAnalysis.create).mockResolvedValue({
+      id: "analysis-123",
+      status: "PROCESSING",
+    } as never);
+
+    await POST(makePostRequest({ projectId: "project-1" }));
+
+    expect(prisma.skillGapAnalysis.create).toHaveBeenCalledWith({
+      data: {
+        projectId: "project-1",
+        requestedById: "user-1",
+        status: "PROCESSING",
+      },
+    });
+  });
+
+  it("returns 500 on database error", async () => {
+    vi.mocked(getServerSession).mockResolvedValue(mockSession as never);
+    vi.mocked(prisma.skillGapAnalysis.create).mockRejectedValue(
+      new Error("DB error")
+    );
+
+    const res = await POST(makePostRequest({ projectId: "project-1" }));
+    expect(res.status).toBe(500);
+  });
+});
diff --git a/src/__tests__/api/auth/register.test.ts b/src/__tests__/api/auth/register.test.ts
new file mode 100644
index 0000000..9dcad5e
--- /dev/null
+++ b/src/__tests__/api/auth/register.test.ts
@@ -0,0 +1,117 @@
+import { describe, it, expect, vi, beforeEach } from "vitest";
+import { NextRequest } from "next/server";
+
+vi.mock("@/lib/prisma", () => ({
+  prisma: {
+    user: {
+      findUnique: vi.fn(),
+      create: vi.fn(),
+    },
+  },
+}));
+
+vi.mock("bcryptjs", () => ({
+  default: {
+    hash: vi.fn().mockResolvedValue("hashed-password"),
+  },
+}));
+
+import { prisma } from "@/lib/prisma";
+import { POST } from "@/app/api/auth/register/route";
+
+function makeRequest(body: unknown) {
+  return new NextRequest("http://localhost/api/auth/register", {
+    method: "POST",
+    headers: { "Content-Type": "application/json" },
+    body: JSON.stringify(body),
+  });
+}
+
+describe("POST /api/auth/register", () => {
+  beforeEach(() => vi.clearAllMocks());
+
+  it("returns 400 for missing required fields", async () => {
+    const res = await POST(makeRequest({}));
+    expect(res.status).toBe(400);
+    const body = await res.json();
+    expect(body.error).toBeDefined();
+  });
+
+  it("returns 400 for invalid email", async () => {
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "not-an-email", password: "password123" })
+    );
+    expect(res.status).toBe(400);
+  });
+
+  it("returns 400 for password shorter than 8 characters", async () => {
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "alice@example.com", password: "short" })
+    );
+    expect(res.status).toBe(400);
+  });
+
+  it("returns 400 for name shorter than 2 characters", async () => {
+    const res = await POST(
+      makeRequest({ name: "A", email: "alice@example.com", password: "password123" })
+    );
+    expect(res.status).toBe(400);
+  });
+
+  it("returns 409 when email is already registered", async () => {
+    vi.mocked(prisma.user.findUnique).mockResolvedValue({
+      id: "existing-user",
+      email: "alice@example.com",
+    } as never);
+
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "alice@example.com", password: "password123" })
+    );
+    expect(res.status).toBe(409);
+    const body = await res.json();
+    expect(body.error).toBe("Email already registered");
+  });
+
+  it("returns 201 with user data on successful registration", async () => {
+    vi.mocked(prisma.user.findUnique).mockResolvedValue(null);
+    vi.mocked(prisma.user.create).mockResolvedValue({
+      id: "new-user-id",
+      name: "Alice",
+      email: "alice@example.com",
+    } as never);
+
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "alice@example.com", password: "password123" })
+    );
+    expect(res.status).toBe(201);
+    const body = await res.json();
+    expect(body.id).toBe("new-user-id");
+    expect(body.name).toBe("Alice");
+    expect(body.email).toBe("alice@example.com");
+  });
+
+  it("does not include password in the response", async () => {
+    vi.mocked(prisma.user.findUnique).mockResolvedValue(null);
+    vi.mocked(prisma.user.create).mockResolvedValue({
+      id: "new-user-id",
+      name: "Alice",
+      email: "alice@example.com",
+    } as never);
+
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "alice@example.com", password: "password123" })
+    );
+    const body = await res.json();
+    expect(body.password).toBeUndefined();
+  });
+
+  it("returns 500 when database throws", async () => {
+    vi.mocked(prisma.user.findUnique).mockResolvedValue(null);
+    vi.mocked(prisma.user.create).mockRejectedValue(new Error("DB connection lost"));
+
+    const res = await POST(
+      makeRequest({ name: "Alice", email: "alice@example.com", password: "password123" })
+    );
+    expect(res.status).toBe(500);
+  });
+});
